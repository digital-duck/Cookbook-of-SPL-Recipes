WORKFLOW review_agent
  INPUT @draft TEXT
  OUTPUT @final TEXT
DO
  @quality := 0.0;
  @current := @draft;
  WHILE @quality < 0.8 DO
    GENERATE rewrite(@current, style='improved') INTO @current;
    GENERATE sentiment(@current) INTO @quality;
  END;
  @final := @current;
  COMMIT @final;

CREATE FUNCTION rewrite(text TEXT, style TEXT)
RETURNS TEXT AS $$
  CASE style
    WHEN 'improved' THEN text || '.'
    WHEN 'standard' THEN text || ','
    ELSE text
  END;
$$;

CREATE FUNCTION sentiment(text TEXT) RETURNS NUMBER AS $$
  RETURN length(trim(text));
$$;