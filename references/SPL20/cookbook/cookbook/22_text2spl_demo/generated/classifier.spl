PROMPT classify_intent
SELECT @input AS text LIMIT 100 TOKENS
GENERATE classify(text) WITH OUTPUT BUDGET 200 TOKENS INTO @intent;

WORKFLOW route_handler
  INPUT @intent TEXT
  OUTPUT @handler TEXT
DO
  EVALUATE
    WHEN 'greeting' THEN
      @handler := 'handle_greeting';
    WHEN 'question' THEN
      @handler := 'handle_question';
    OTHERWISE
      @handler := 'default_handler';
  END;
END;